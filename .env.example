# ======================
# Backend (common)
# ======================
APP_ENV=development
PORT=5001
DATABASE_URL=sqlite:///classqr.db
JWT_SECRET_KEY=change-me
SECRET_KEY=dev-secret-key-change-me
SEED_DATA=true

# ======================
# CORS / QR
# ======================
# development default: localhost + (optional) LAN if CORS_ALLOW_LAN=true
# production default: set CORS_ORIGINS explicitly, and disable LAN
QR_FRONTEND_ORIGIN=https://SenyaByy.pythonanywhere.com
CORS_ALLOW_LAN=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://SenyaByy.pythonanywhere.com

# ======================
# Frontend (optional for dev, Vite)
# ======================
VITE_PROXY_TARGET=http://127.0.0.1:5001
VITE_QR_ORIGIN=https://SenyaByy.pythonanywhere.com

# ======================
# Production example (override)
# ======================
# APP_ENV=production
# SEED_DATA=false
# CORS_ALLOW_LAN=false
# CORS_ORIGINS=https://SenyaByy.pythonanywhere.com

